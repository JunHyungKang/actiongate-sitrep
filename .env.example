# Copy to .env and fill in.

# Signing secret from the SitRep Studio (shown once when you save a Remote agent).
# Leave blank for pure local dev — signature checks are skipped when unset.
SITREP_AGENT_SECRET=

# ── LLM: defaults to a free local Ollama. No signup, no cost. ──────────
#   1) install:  https://ollama.com
#   2) pull:     ollama pull llama3.2:1b
LLM_BASE_URL=http://localhost:11434/v1
MODEL=llama3.2:1b
LLM_TIMEOUT_SECONDS=45
LLM_MAX_INPUT_CHARS=12000
LLM_MAX_DAILY_CALLS=50
# LLM_API_KEY is unused by Ollama.

# ── BYOK alternatives (uncomment one) ─────────────────────────────────
# OpenAI:
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...
# MODEL=gpt-4o-mini
#
# OpenRouter (has free models):
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_API_KEY=sk-or-...
# MODEL=meta-llama/llama-3.1-8b-instruct:free
